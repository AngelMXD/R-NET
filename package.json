  "scripts": {
    "start": "retype start",
    "build": "npm run changelog && retype build",
    "changelog": "python \"3.Acerca-de/generar_changelog.py\"",
    "optimize": "npm run build && if not exist site\\static\\purged mkdir site\\static\\purged && npx purgecss --config ./purgecss.config.mjs --output site/static/purged && copy /Y site\\static\\purged\\custom.css site\\static\\custom.min.css",
    "optimize:report": "if not exist logs mkdir logs && npm run build && if not exist site\\static\\purged mkdir site\\static\\purged && npx purgecss --config ./purgecss.config.mjs --rejected --output site/static/purged > logs\\purgecss-rejected.txt && copy /Y site\\static\\purged\\custom.css site\\static\\custom.min.css && type logs\\purgecss-rejected.txt",
    "rebuild:recursos": "node generar_recursos.js && retype start"
  },
