generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id       Int      @id @default(autoincrement())
  nombre   String
  email    String
  mensaje  String
  estado   String   @default("abierto") // 👈 estado del ticket
  creadoEn DateTime @default(now())
}
